rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isStringField(path) { return request.resource.data[path] is string; }
    function isNumberField(path) { return request.resource.data[path] is number; }
    function hasKeys(required) { return request.resource.data.keys().hasAll(required); }

    // Users namespace: default deny; allow owner-only read/write
    match /users/{uid} {
      allow read, write: if false;

      // Reading progress (PDF)
      match /readingProgress/{bookId} {
        allow read, list: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && hasKeys(['totalPages','currentPage'])
          && isNumberField('totalPages') && isNumberField('currentPage')
          && request.resource.data.totalPages >= 0
          && request.resource.data.currentPage >= 0;
        allow delete: if isOwner(uid);
      }

      // Audio progress
      match /audioProgress/{audioId} {
        allow read, list: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && hasKeys(['durationMs','positionMs','playing'])
          && isNumberField('durationMs') && isNumberField('positionMs')
          && request.resource.data.durationMs >= 0
          && request.resource.data.positionMs >= 0
          && (request.resource.data.playing is bool);
        allow delete: if isOwner(uid);
      }

      // Reading time logs
      match /readingTime/{logId} {
        allow read, list: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && hasKeys(['minutes','ts'])
          && isNumberField('minutes') && isNumberField('ts')
          && request.resource.data.minutes >= 0
          && request.resource.data.ts > 0;
        allow delete: if isOwner(uid);
      }

      // My Library
      match /my_library/{itemId} {
        allow read, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid);
      }

      // Favorites
      match /favorites/{itemId} {
        allow read, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid)
          && hasKeys(['id'])
          && isStringField('id');
      }

      // Recently Viewed
      match /recentlyViewed/{itemId} {
        allow read, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid)
          && hasKeys(['id','ts'])
          && isStringField('id') && isNumberField('ts');
      }

      // Reading Goals
      match /readingGoals/{goalId} {
        allow read, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid);
      }

      // Per-day activity marker
      match /appActivity/{dayKey} {
        allow read, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid)
          && hasKeys(['ts'])
          && isNumberField('ts') && request.resource.data.ts > 0;
      }

      // Notes overlay
      match /notes/{bookId} {
        allow read, list: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && hasKeys(['text'])
          && isStringField('text')
          && request.resource.data.text.size() <= 20000;
        allow delete: if isOwner(uid);
      }

      // Mind Maps
      match /mindmaps/{mapId} {
        allow read, list: if isOwner(uid);
        allow create, update, delete: if isOwner(uid);
      }
    }

    // Public reviews (read-only; authenticated users can create)
    match /reviews/{reviewId} {
      allow read, list: if true;

      // Create review (auth required)
      allow create: if isSignedIn()
        && hasKeys(['text','rating','bookType'])
        && isStringField('text') && isNumberField('rating') && isStringField('bookType')
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 10000
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;

      // Update/Delete only by original author
      allow update, delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      // Comments under a review
      match /comments/{commentId} {
        allow read, list: if true;
        allow create: if isSignedIn()
          && hasKeys(['text','userId'])
          && isStringField('text') && isStringField('userId')
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 5000;
        allow update, delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;
      }
    }

    // Notifications
    match /notifications/{id} {
      // Read: recipient-only or broadcast
      allow read: if isSignedIn()
        && (resource.data.type == 'broadcast' || resource.data.to == request.auth.uid);

      // Create: only personal notifications from the recipient client
      // Prevent creating for other users
      allow create: if isSignedIn()
        && request.resource.data.type == 'personal'
        && request.resource.data.to == request.auth.uid
        && hasKeys(['type','to','title','message','read'])
        && isStringField('title') && isStringField('message')
        && (request.resource.data.read is bool)
        && request.resource.data.title.size() > 0
        && request.resource.data.message.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.message.size() <= 2000;

      // Update: recipient can only toggle 'read'
      allow update: if isSignedIn()
        && resource.data.to == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && (request.resource.data.read is bool);

      // Delete: recipient can delete their own personal notifications
      allow delete: if isSignedIn()
        && resource.data.to == request.auth.uid
        && resource.data.type == 'personal';
    }
  }
}
